<?xml version="1.0" encoding="UTF-8"?>
<Ufex xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<FileTypes>
		<FileType>
			<ID>VIDEO_AVI</ID>
			<ParentID>BASE_RIFF</ParentID>
			<Description>Audio Video Interleave</Description>
			<Category>Video</Category>
			<MIMETypes>
				<MIMEType>video/x-msvideo</MIMEType>
			</MIMETypes>
			<Wikipedia/>
			<Extensions>
				<Extension>avi</Extension>
			</Extensions>
			<Signatures>
				<Signature>
					<Rule type="string" offset="0">RIFF</Rule>
					<Rule type="string" offset="8">AVI </Rule>
				</Signature>
			</Signatures>
		</FileType>
		<FileType>
			<ID>VIDEO_QUICKTIME</ID>
			<Description>Quicktime Video</Description>
			<Category>Video</Category>
			<MIMETypes>
				<MIMEType>video/quicktime</MIMEType>
			</MIMETypes>
			<Wikipedia/>
			<Extensions>
				<Extension>mov</Extension>
			</Extensions>
		</FileType>
		<FileType>
			<ID>VIDEO_M2TS</ID>
			<Description>BDAV MPEG-2 Transport Stream</Description>
			<Category>Video</Category>
			<MIMETypes>
				<MIMEType>video/MP2T</MIMEType>
			</MIMETypes>
			<Wikipedia>.m2ts</Wikipedia>
			<Extensions>
				<Extension>m2ts</Extension>
			</Extensions>
		</FileType>
	</FileTypes>
</Ufex>
