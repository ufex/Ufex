<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Ufex.Controls.Avalonia"
             x:Class="Ufex.Desktop.Views.StructureTabView">
    
    <Grid ColumnDefinitions="*,Auto,2*">
        
        <!-- Left Panel: Tree View -->
        <Border Grid.Column="0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,0,0"
                Margin="4">
            <TreeView x:Name="TreeViewStructure"
                      SelectionMode="Single" />
        </Border>
        
        <!-- GridSplitter for resizing -->
        <GridSplitter Grid.Column="1"
                      Width="4"
                      Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                      ResizeDirection="Columns" />
        
        <!-- Right Panel: Visual Content Area -->
        <Border Grid.Column="2"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0"
                Margin="4">
            <!-- ContentControl for single visual, or TabControl for multiple -->
            <Panel x:Name="VisualsContainer">
                <!-- Single visual display (no tabs) -->
                <ContentControl x:Name="SingleVisualContent" IsVisible="False" />
                
                <!-- Multiple visuals display (tabs) -->
                <TabControl x:Name="VisualsTabControl" IsVisible="False" />
            </Panel>
        </Border>
        
    </Grid>
    
</UserControl>
