<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Ufex.Controls.Avalonia"
             x:Class="Ufex.Desktop.Views.HexTabView">

    <DockPanel>
        <controls:HexSearchBar x:Name="HexSearchBar" DockPanel.Dock="Top" HorizontalAlignment="Left" Margin="0,4,0,4" />
        <controls:HexView x:Name="HexViewer" />
    </DockPanel>

</UserControl>
